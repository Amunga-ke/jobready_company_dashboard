# ─── Database ───
DATABASE_URL=mysql://user:password@host:3306/database_name

# ─── NextAuth ───
NEXTAUTH_URL=http://localhost:3001
NEXTAUTH_SECRET=your-nextauth-secret-change-in-production

# ─── M-Pesa Daraja ───
MPESA_BUSINESS_SHORTCODE=174379
MPESA_TRANSACTION_TYPE=CustomerPayBillOnline
MPESA_PARTY_B=174379
MPESA_CONSUMER_KEY=your_consumer_key
MPESA_CONSUMER_SECRET=your_consumer_secret
MPESA_PASSKEY=your_passkey
MPESA_CALLBACK_URL=https://api.jobready.co.ke/payments/mpesa/callback
MPESA_ENVIRONMENT=sandbox

# ─── Token Encryption ───
# AES-256-GCM key for encrypting OAuth tokens stored in the database.
# Generate one via: GET /api/employer/social/generate-key (dev mode only)
# Must be a 64-character hex string (32 bytes).
TOKEN_ENCRYPTION_KEY=
